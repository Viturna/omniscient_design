<% content_for :title, "Ressources officielles - Omniscient Design" %>
<% content_for :description, "Retrouve les sujets du bac officiels de 2021 à aujourd'hui et télécharge-les pour les consulter." %>

<style>
  /* Fix pour position: sticky qui peut être cassé par des parents avec overflow: hidden */
  html, body {
    overflow-x: visible !important;
  }

  .ressources-container {
    background-color: #FFF;
    min-height: 100vh;
    padding-top: 100px;
    display: grid;
    grid-template-columns: 1fr 300px; /* Contenu à gauche, sommaire à droite */
    gap: 5vw;
    align-items: start; /* Empêche les éléments de s'étirer en hauteur */
  }
  
  .ressources-main {
    width: 100%;
  }
  
  .ressources-sidebar {
    position: -webkit-sticky;
    position: sticky;
    top: 100px;
    height: fit-content;
    background: #202020;
    padding: 32px;
    border-radius: 16px;
    z-index: 10;
  }
  
  .year-section {
    margin-bottom: 64px;
  }
  
  .year-title {
    font-size: 22px;
    font-weight: 400;
    margin-bottom: 32px;
    color: #202020;
  }
  
  .flex-buttons-ressource {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
    align-items: center;
  }
  
  .button-ressource {
    width: fit-content;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .file-size {
    font-size: 12px;
    font-weight: 300;
    opacity: 0.7;
    margin-left: 4px;
  }
  
  .preview-btn {
    background: #F0F0F0;
    color: #202020;
    padding: 18px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    height: 32px;
    width: 32px;
  }

  .preview-btn:hover {
    background: #E0E0E0;
    transform: translateY(-2px);
  }
  
  .button-ressource svg, .preview-btn svg {
    width: 24px;
    height: 24px;
  }

  .sommaire-title {
    font-weight: 500;
    margin-bottom: 32px;
    font-size: 22px;
    color: #FFF;
  }
  
  .sommaire-list {
    list-style: none;
    padding: 0;
  }
  
  .sommaire-list li {
    margin-bottom: 20px;
  }
  
  .sommaire-list a {
    color: #FFF;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 20px;
    font-weight: 400;
    position: relative;
  }

  .sommaire-list a span {
    font-weight: 500;
  }
  
  .sommaire-list li.active a {
    transform: translateX(12px);
    font-weight: 600;
  }

  .sommaire-list li.active a::before {
    content: "|";
    position: absolute;
    left: -15px;
    font-weight: 400;
  }

  .sommaire-list a:hover {
    color: #FFF;
    text-decoration: underline;
  }

  .btn-all-subjects {
     margin-bottom: 48px;
  }

  .session-label {
    font-size: 14px;
    font-weight: 400;
    color: #888;
    margin: 24px 0 16px 0;
  }

  @media screen and (max-width: 1250px) {
    .ressources-container {
      grid-template-columns: 1fr;
      gap: 64px;
      padding-top: 48px;
    }
    .ressources-sidebar {
      width: auto;
      box-sizing: border-box;
      position: static;
      order: -1; /* Place le sommaire au-dessus du contenu */
      padding: 24px;
    }
    .flex-buttons-ressource {
      align-items: flex-start;
      flex-direction: column-reverse;
      flex-wrap: wrap;
      gap: 8px;
    }
    .button-ressource {
      width: auto;
      box-sizing: border-box;
      justify-content: center;
      font-size: 14px;
    }
    .preview-btn {
      width: auto;
      box-sizing: border-box;
      height: 48px;
    }
    .year-title {
      font-size: 20px;
      margin-bottom: 24px;
    }
    .sommaire-title {
      font-size: 18px;
      margin-bottom: 20px;
    }
    .sommaire-list li {
      margin-bottom: 12px;
    }
    .sommaire-list a {
      font-size: 16px;
    }
  }

  @media screen and (max-width: 600px) {
    .ressources-container {
      padding-top: 32px;
    }
    .top-header h1 {
      font-size: 28px;
    }
    .subtitle {
      font-size: 14px;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    margin-bottom: 24px;
    transition: opacity 0.2s;
  }
  .back-link:hover {
    opacity: 0.7;
  }
</style>

