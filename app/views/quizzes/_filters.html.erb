<!-- Barre de filtres compacte -->
<div class="hub-filters-toolbar">
  <%= form_with url: quizzes_hub_path, method: :get, class: "hub-filters-form" do |f| %>
    <% if params[:category].present? %>
      <%= f.hidden_field :category, value: params[:category] %>
    <% end %>
    <div class="filter-wrapper <%= 'active' if params[:domaine_id].present? %>">
      <svg class="icon-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
      <%= f.select :domaine_id, 
                   Domaine.all.map { |d| [d.domaine, d.id] }, 
                   { include_blank: "Domaine", selected: params[:domaine_id] }, 
                   { class: "hub-filter-select", onchange: "this.form.submit()" } %>
      <svg class="icon-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>

    <div class="filter-wrapper <%= 'active' if params[:count_range].present? %>">
      <svg class="icon-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      <%= f.select :count_range, 
                   [["Court", "small"], ["Moyen", "medium"], ["Long", "large"]], 
                   { include_blank: "Durée", selected: params[:count_range] }, 
                   { class: "hub-filter-select", onchange: "this.form.submit()" } %>
      <svg class="icon-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>

    <div class="filter-wrapper <%= 'active' if params[:status].present? %>">
      <svg class="icon-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      <%= f.select :status, 
                   [["Pas commencé", "not_started"], ["En cours", "in_progress"], ["Terminé", "completed"]], 
                   { include_blank: "État", selected: params[:status] }, 
                   { class: "hub-filter-select", onchange: "this.form.submit()" } %>
      <svg class="icon-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
    </div>

    <% if params[:domaine_id].present? || params[:count_range].present? || params[:status].present? %>
      <%= link_to quizzes_hub_path(category: params[:category]), class: "hub-filter-reset", title: "Réinitialiser" do %>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6"></path><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
      <% end %>
    <% end %>
  <% end %>
</div>
