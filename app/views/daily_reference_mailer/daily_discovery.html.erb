<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
</head>
<body style="margin:0; padding:0; background-color:#f4f4f4; font-family:Arial, sans-serif;">
  <table align="center" width="680" cellpadding="0" cellspacing="0" style="margin:40px auto; background:#ffffff; border-radius:12px;">
    <tr>
      <td style="padding:40px;">

        <!-- Logo -->
        <a href="https://omniscientdesign.fr" target="_blank" style="text-decoration:none; color:#202020;">
          <table cellpadding="0" cellspacing="0">
            <tr>
              <td><img src="https://omniscientdesign.fr/assets/mail-logo.png" alt="Omniscient Design" width="55" style="display:block; border:0;" /></td>
              <td style="padding-left:12px; font-size:24px; font-weight:600; color:#202020;">
                Omniscient<br/>Design
              </td>
            </tr>
          </table>
        </a>

        <!-- Texte d’introduction -->
        <p style="margin:30px 0 10px 0; font-size:16px; line-height:1.5; color:#52525D;">
          La réf du jour
        </p>

        <!-- Titre -->
        <h2 style="font-size:28px; text-transform:uppercase; margin:0 0 20px 0; color:#202020;">
          <%= @reference.nom_reference %>
        </h2>

        <!-- Salutation -->
        <p style="font-size:16px; line-height:1.5; color:#52525D;">
          Bonjour <strong style="color:#202020;"><%= @user.firstname.presence || @user.pseudo.presence || @user.email %></strong>,
        </p>

        <!-- Image de la référence -->
        <% if @reference.reference_images.any? %>
          <% image = @reference.reference_images.first.file %>
          <div style="margin: 20px 0; border-radius: 8px; overflow: hidden;">
            <%= image_tag attachments[image.filename.to_s].url, style: "width: 100%; max-height: 400px; object-fit: cover; display: block;" if attachments[image.filename.to_s] %>
          </div>
        <% end %>

        <!-- Corps du mail -->
        <p style="font-size:16px; line-height:1.5; color:#52525D;">
          Aujourd'hui, nous vous proposons de découvrir <strong>"<%= @reference.nom_reference %>"</strong>.
          <% if @reference.designers.any? %>
            Une référence de <strong><%= @reference.designers.map(&:nom_designer).join(', ') %></strong>.
          <% end %>
        </p>

        <% if @reference.presentation_generale.present? %>
          <p style="font-size:16px; line-height:1.5; color:#52525D; font-style: italic; border-left: 3px solid #202020; padding-left: 15px; margin: 20px 0;">
            <%= truncate(@reference.presentation_generale, length: 250) %>
          </p>
        <% end %>

        <!-- Bouton -->
        <table align="center" cellpadding="0" cellspacing="0" style="margin:30px auto;">
          <tr>
            <td align="center" bgcolor="#202020" style="border-radius:5px;">
              <a href="<%= reference_url(@reference, locale: I18n.locale) %>"
                 style="display:inline-block; padding:16px 30px; font-size:16px; font-weight:500; color:#ffffff; text-decoration:none;">
                Voir la référence complète
              </a>
            </td>
          </tr>
        </table>

        <p style="font-size:14px; line-height:1.5; color:#888;">
          Vous recevez ce mail car vous avez activé la découverte quotidienne dans vos réglages.
          <a href="<%= notifications_settings_url(locale: I18n.locale) %>" style="color: #888; text-decoration: underline;">Se désabonner</a>
        </p>

        <!-- Signature -->
        <p style="font-style:italic; color:#202020; margin-top:30px;">
          À demain pour une nouvelle source d'inspiration,<br/>
          <strong>
            L'équipe
            <a href="https://omniscientdesign.fr" target="_blank" style="color:#202020;">
              Omniscient Design
            </a>
          </strong>
        </p>

        <!-- Footer -->
        <table align="center" cellpadding="0" cellspacing="0" width="100%"
               style="background-color:#F8F8F8; border-radius:12px; padding:30px; margin-top:30px;">
          <tr>
            <td align="center">

              <!-- Réseaux sociaux -->
              <table align="center" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                <tr>
                  <td><a href="https://omniscientdesign.fr/" target="_blank"><img src="https://omniscientdesign.fr/assets/link.png" alt="Site" width="30" style="display:block;border:0;"></a></td>
                  <td style="width:10px;"></td>
                  <td><a href="https://www.instagram.com/omniscientdesign_/" target="_blank"><img src="https://omniscientdesign.fr/assets/instagram.png" alt="Instagram" width="40" style="display:block;border:0;"></a></td>
                  <td style="width:10px;"></td>
                  <td><a href="https://www.linkedin.com/company/omniscient-design/" target="_blank"><img src="https://omniscientdesign.fr/assets/linkedin.png" alt="LinkedIn" width="40" style="display:block;border:0;"></a></td>
                  <td style="width:10px;"></td>
                  <td><a href="https://www.tiktok.com/@omniscientdesign_" target="_blank"><img src="https://omniscientdesign.fr/assets/tiktok.png" alt="TikTok" width="40" style="display:block;border:0;"></a></td>
                  <td style="width:10px;"></td>
                  <td><a href="mailto:contact@omniscientdesign.fr"><img src="https://omniscientdesign.fr/assets/mail.png" alt="Email" width="40" style="display:block;border:0;"></a></td>
                </tr>
              </table>

              <!-- Liens légaux -->
              <p style="text-align:center; font-size:14px; margin:0 0 16px 0; color:#202020;">
                <a href="https://omniscientdesign.fr/mentionslegales" style="color:#202020; text-decoration:underline;">Mentions légales</a> |
                <a href="https://omniscientdesign.fr/politiquedeconfidentialite" style="color:#202020; text-decoration:underline;">Politique de confidentialité</a> |
                <a href="https://omniscientdesign.fr/cgu" style="color:#202020; text-decoration:underline;">CGU</a>
              </p>

              <!-- Copyright -->
              <p style="text-align:center; font-size:14px; color:#202020; margin:0;">
                ©<%= Time.current.year %> Omniscient Design — Tous droits réservés
              </p>

            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>
</html>
