<style>
  .admin-form-container {
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .admin-form-group { margin-bottom: 28px; }
  .admin-form-group label { 
    display: block; 
    font-weight: 600; 
    margin-bottom: 10px; 
    color: #202020;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .admin-form-input { 
    width: 100%; 
    padding: 14px 18px; 
    border: 1px solid #E0E0E0; 
    border-radius: 12px; 
    font-size: 15px; 
    box-sizing: border-box;
    transition: all 0.2s ease;
    background: #FDFDFD;
  }
  
  .admin-form-input:focus {
    outline: none;
    border-color: #202020;
    box-shadow: 0 0 0 4px rgba(32, 32, 32, 0.05);
    background: #FFF;
  }

  .section-header-admin {
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    margin: 60px 0 30px; 
    padding-bottom: 20px;
    border-bottom: 1px solid #EEE;
  }

  .btn-add {
    background: #F5F5F7;
    color: #202020;
    border: 1px solid #E0E0E0;
    padding: 12px 20px;
    border-radius: 12px;
    font-weight: 600;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-add:hover {
    background: #EEE;
    transform: translateY(-1px);
  }

  /* Question Blocks */
  .question-block { 
    background: #FFF; 
    padding: 32px; 
    border-radius: 20px; 
    margin-bottom: 40px; 
    border: 1px solid #EEE;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .question-block:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    border-color: #DDD;
  }

  .question-header { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    margin-bottom: 24px; 
  }
  
  .question-number-badge {
    background: #202020;
    color: #FFF;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
  }

  .action-btn {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #EEE;
    background: #FFF;
    cursor: pointer;
    transition: all 0.2s ease;
    color: #666;
  }

  .action-btn.delete:hover {
    background: #FEE;
    color: #E53935;
    border-color: #FFCDD2;
  }

  /* Answers */
  .answers-grid { 
    display: grid; 
    grid-template-columns: 1fr 1fr; 
    gap: 20px; 
    margin-top: 24px;
  }
  
  .answer-item { 
    background: #FAFAFA; 
    padding: 16px; 
    border-radius: 14px; 
    border: 1px solid #EEE; 
    display: flex; 
    align-items: center; 
    gap: 14px; 
    transition: all 0.2s ease;
  }

  .answer-item:focus-within {
    background: #FFF;
    border-color: #202020;
  }

  .answer-item.is-correct {
    background: #E8F5E9;
    border-color: #2E7D32;
  }

  .answer-checkbox { 
    width: 22px; 
    height: 22px; 
    cursor: pointer; 
    accent-color: #2E7D32;
  }
  
  /* Footer Actions */
  .form-footer-sticky {
    position: sticky;
    bottom: 30px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    padding: 20px;
    border-radius: 20px;
    border: 1px solid #EEE;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    margin-top: 60px;
    z-index: 100;
    display: flex;
    justify-content: flex-end;
  }

  .btn-submit { 
    background: #202020; 
    color: #FFF; 
    border: none; 
    padding: 18px 40px; 
    border-radius: 14px; 
    font-weight: 600; 
    cursor: pointer; 
    font-size: 16px; 
    transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  
  .btn-submit:hover { 
    background: #333; 
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }
</style>

<div class="admin-form-container">
  <%= form_with(model: [:admin, quiz], data: { controller: "nested-form" }) do |f| %>
    <% if quiz.errors.any? %>
      <div style="color: red; margin-bottom: 32px; padding: 24px; background: #FFF; border: 1px solid #FFCDD2; border-radius: 16px;">
        <h2 style="font-size: 18px; margin-bottom: 12px;"><%= pluralize(quiz.errors.count, "erreur") %> empêchent l'enregistrement :</h2>
        <ul style="margin: 0; padding-left: 20px; color: #D32F2F;">
          <% quiz.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="dash-card" style="padding: 40px; margin-bottom: 40px;">
      <div class="admin-form-group">
        <%= f.label :title, "Titre du Quiz" %>
        <%= f.text_field :title, class: "admin-form-input", placeholder: "Ex: Le Design Radical Italien" %>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div class="admin-form-group">
          <%= f.label :domaine_id, "Domaine" %>
          <%= f.collection_select :domaine_id, Domaine.all, :id, :domaine, { include_blank: "Sélectionner un domaine" }, { class: "admin-form-input" } %>
        </div>
        <div class="admin-form-group">
          <%= f.label :estimated_time, "Temps estimé (min)" %>
          <%= f.number_field :estimated_time, class: "admin-form-input", placeholder: "Ex: 10" %>
        </div>
      </div>
    </div>

    <div class="section-header-admin">
      <h2 style="margin: 0; font-size: 28px; font-weight: 700; color: #202020;">Questions</h2>
      <button type="button" class="btn-add" data-action="nested-form#add">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Ajouter une question
      </button>
    </div>

    <div id="questions-container" data-nested-form-target="container">
      <%= f.fields_for :quiz_questions do |q_f| %>
        <%= render 'question_fields', f: q_f %>
      <% end %>
    </div>

    <!-- Template pour les nouvelles questions -->
    <template data-nested-form-target="template">
      <%= f.fields_for :quiz_questions, QuizQuestion.new, child_index: 'NEW_RECORD' do |q_f| %>
        <%= render 'question_fields', f: q_f, is_new: true %>
      <% end %>
    </template>

    <div class="form-footer-sticky">
      <%= f.submit (quiz.new_record? ? "Créer le Quiz" : "Enregistrer les modifications"), class: "btn-submit" %>
    </div>
  <% end %>
</div>
