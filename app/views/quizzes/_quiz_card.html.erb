<div class="quiz-card">
  <div class="card-image">
    <% 
      # On cherche l'image du quiz de manière plus efficace
      # On prend la première question qui a une référence avec image
      submission = @user_submissions_by_quiz[quiz.id]
      
      # Optimisation : On essaie de récupérer une image via les associations déjà chargées si possible
      # Sinon on fait une requête ciblée
      first_question = quiz.quiz_questions.first
      reference_with_image = Reference.joins(:reference_images)
                                      .where(id: quiz.quiz_questions.select(:reference_id))
                                      .first
      
      # Fallback domaine
      reference_with_image ||= quiz.domaine&.references&.joins(:reference_images)&.first
    %>
    <% if reference_with_image && reference_with_image.reference_images.first&.file&.attached? %>
      <%= image_tag reference_with_image.reference_images.first.file.variant(resize_to_fill: [400, 300]) %>
    <% else %>
      <div class="placeholder-img"></div>
    <% end %>
  </div>
  
  <div class="card-content">
    <div class="card-badges">
      <% if submission&.status == "completed" %>
        <span class="badge status status-completed">
          TERMINÉ • <%= submission.score %>/<%= quiz.quiz_questions.size * 10 %> pts
        </span>
      <% elsif submission&.status == "in_progress" %>
        <span class="badge status status-in-progress">EN COURS</span>
      <% else %>
        <span class="badge status">À FAIRE</span>
      <% end %>
      <% if quiz.domaine %>
        <span class="badge domaine"><%= quiz.domaine.domaine %></span>
      <% end %>
    </div>

    <h3><%= quiz.title %></h3>
    
    <div class="card-info">
      <div class="info-item">
        <span><%= quiz.quiz_questions.count %> Questions</span>
      </div>
      <div class="info-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 6V12L16 14M22 12C22 17.5228 17.5228 22 12 22C6.47715 22 2 17.5228 2 12C2 6.47715 6.47715 2 12 2C17.5228 2 22 6.47715 22 12Z" stroke="#52525D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span><%= quiz.estimated_time || 5 %> min</span>
      </div>
    </div>

    <%= link_to (quiz.in_progress_by?(current_user) ? "Continuer" : "Faire le quizz"), quiz_path(quiz), class: "button dark w-full" %>
  </div>
</div>
