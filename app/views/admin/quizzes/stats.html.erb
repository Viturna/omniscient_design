<style>
  .users-dash-wrapper {
    padding: 40px 4vw 80px 4vw;
    max-width: 1600px;
    margin: 0 auto;
    background-color: #f8f9fa;
    min-height: 100vh;
    font-family: 'IBM Plex Sans', sans-serif;
    color: #202020;
    box-sizing: border-box;
  }
  .users-dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
  .users-dash-title { font-size: 32px; font-weight: 500; color: #202020; display: flex; align-items: center; gap: 16px; margin: 0; }
  .users-dash-back-link { display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background-color: #fff; border: 1px solid #eee; transition: all 0.2s ease; }

  .nav-tabs { display: flex; gap: 12px; margin-bottom: 32px; }
  .nav-tab { padding: 10px 20px; border-radius: 10px; text-decoration: none; color: #666; font-weight: 500; background: #eee; }
  .nav-tab.active { background: #202020; color: #fff; }

  .kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 40px; }
  .kpi-card { background: #fff; padding: 24px; border-radius: 16px; border: 1px solid #f0f0f0; }
  .kpi-label { color: #888; font-size: 14px; text-transform: uppercase; margin-bottom: 8px; display: block; }
  .kpi-value { font-size: 32px; font-weight: 600; }

  .stats-table-container { background: #fff; border-radius: 16px; border: 1px solid #f0f0f0; overflow: hidden; }
  .stats-table { width: 100%; border-collapse: collapse; }
  .stats-table th { background: #fafafa; padding: 18px 24px; text-align: left; font-size: 12px; font-weight: 600; border-bottom: 1px solid #eee; }
  .stats-table td { padding: 18px 24px; border-bottom: 1px solid #f5f5f5; }
</style>

<div class="users-dash-wrapper">
  <div class="users-dash-header">
    <div style="display: flex; align-items: center; gap: 20px;">
      <%= link_to admin_quizzes_path, class: "users-dash-back-link" do %>
        <svg style="width: 24px; height: 24px; fill: #202020;" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      <% end %>
      <h1 class="users-dash-title">Statistiques des Quiz</h1>
    </div>
  </div>

  <div class="nav-tabs">
    <%= link_to "Liste des Quiz", admin_quizzes_path, class: "nav-tab" %>
    <%= link_to "Statistiques", stats_admin_quizzes_path, class: "nav-tab active" %>
    <%= link_to "Historique des Sessions", sessions_admin_quizzes_path, class: "nav-tab" %>
  </div>

  <div class="kpi-grid">
    <div class="kpi-card">
      <span class="kpi-label">Total Sessions</span>
      <span class="kpi-value"><%= @total_submissions %></span>
    </div>
    <div class="kpi-card">
      <span class="kpi-label">Score Moyen</span>
      <span class="kpi-value"><%= @avg_score&.round(1) || 0 %> pts</span>
    </div>
    <div class="kpi-card">
      <span class="kpi-label">Quiz Populaires</span>
      <span class="kpi-value"><%= Quiz.where(quiz_type: 'static').count %> actifs</span>
    </div>
  </div>

  <div class="stats-table-container">
    <table class="stats-table">
      <thead>
        <tr>
          <th>Quiz</th>
          <th>Domaine</th>
          <th>Nombre de sessions</th>
          <th>Score Moyen</th>
        </tr>
      </thead>
      <tbody>
        <% @quizzes_stats.each do |quiz| %>
          <tr>
            <td><strong><%= quiz.title %></strong></td>
            <td><%= quiz.domaine&.domaine || "Général" %></td>
            <td><%= quiz.submissions_count %></td>
            <td><%= quiz.average_score&.round(1) %> pts</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
