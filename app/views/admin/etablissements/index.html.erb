<style>
  .col-links {
    white-space: normal;
    min-width: 250px;
    max-width: 350px;
  }
  .col-links a {
    color: #007bff;
    word-break: break-all;
  }
  .col-actions {
    white-space: nowrap;
  }
  .badge-gray {
    background: #eee;
    color: #666;
  }
</style>

<div class="users-dash-wrapper">
  <div class="users-dash-header">
    <div style="display: flex; align-items: center; gap: 20px;">
      <%= link_to admin_root_path, class: "users-dash-back-link" do %>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#202020" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
      <% end %>
      <h1 class="users-dash-title"><%= t('admin.etablissements.index.title') %></h1>
    </div>
  </div>

  <div class="users-dash-kpi-grid">
    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label"><%= t('admin.etablissements.index.total_etablissements') %></span>
        <div class="kpi-icon bg-blue-light">
          <svg viewBox="0 0 24 24"><path d="M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>
        </div>
      </div>
      <div class="kpi-value"><%= @total_etablissements %></div>
    </div>
    
    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label"><%= t('admin.etablissements.index.active_etablissements') %></span>
        <div class="kpi-icon bg-green-light">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-4-4 1.41-1.41L11 14.17l6.59-6.59L19 9l-8 8z"/></svg>
        </div>
      </div>
      <div class="kpi-value"><%= @active_etablissements %></div>
    </div>
    
    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label"><%= t('admin.etablissements.index.linked_users') %></span>
        <div class="kpi-icon bg-yellow-light">
          <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        </div>
      </div>
      <div class="kpi-value"><%= @total_users_linked %></div>
    </div>
  </div>

  <div class="users-dash-toolbar">
    <%= form_with url: admin_etablissements_path, method: :get, local: true, class: "search-form" do |f| %>
      <div class="users-dash-search">
        <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        <%= f.text_field :query, value: params[:query], placeholder: t('admin.etablissements.index.search_placeholder') %>
      </div>
      <%= f.submit t('admin.etablissements.index.search'), class: "users-dash-btn-export", style: "background-color: #202020; color: white; padding: 12px 24px;" %>
      <% if params[:query].present? %>
        <%= link_to t('admin.etablissements.index.clear'), admin_etablissements_path, class: "users-dash-btn-export", style: "background-color: #f5f5f5; color: #202020; border-color: #e0e0e0;" %>
      <% end %>
    <% end %>

    <%= link_to admin_etablissements_path(format: :csv, query: params[:query]), class: "users-dash-btn-export", style: "background-color: #28a745; border-color: #28a745;" do %>
      <svg style="margin-right: 8px;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      <%= t('admin.etablissements.index.export_csv') %>
    <% end %>
  </div>

  <div class="users-dash-table-container">
    <table class="users-dash-table">
      <thead>
        <tr>
          <th>Nom</th>
          <th>Utilisateurs</th>
          <th>UAI</th>
          <th>Statut</th>
          <th>Type</th>
          <th>Localisation</th>
          <th>Coordonnées</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @etablissements.each do |etab| %>
          <tr>
            <td>
              <strong><%= etab.name %></strong>
            </td>
            <td>
              <% count = etab.users_count %>
              <span class="badge <%= count > 0 ? 'badge-green' : 'badge-gray' %>">
                <%= count %>
              </span>
            </td>
            <td><code><%= etab.uai %></code></td>
            <td><%= etab.statut_public_prive %></td>
            <td><%= etab.type_etablissement %></td>
            <td>
              <%= etab.city %> (<%= etab.academy %>)<br>
              <small style="color:#666;"><%= etab.region %></small>
            </td>
            <td class="col-links">
              <% if etab.phone.present? %><%= etab.phone %><br><% end %>
              <% if etab.messagerie.present? %><%= mail_to etab.messagerie %><br><% end %>
              <% if etab.website.present? %><%= link_to "Site web", etab.website, target: "_blank" %><% end %>
            </td>
            <td class="col-actions" style="text-align: right; display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
              <%= link_to "Modifier", edit_admin_etablissement_path(etab), class: "badge badge-blue", style: "text-decoration: none;" %>
              <% if count == 0 %>
                <%= link_to "Supprimer", admin_etablissement_path(etab), 
                      class: "badge badge-red", style: "text-decoration: none;",
                      data: { turbo_method: :delete, turbo_confirm: "Supprimer cet établissement ?" } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <div style="margin-top: 24px;">
    <%= paginate @etablissements %>
  </div>
</div>