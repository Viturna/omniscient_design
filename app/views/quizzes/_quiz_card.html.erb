<div class="quiz-card">
  <div class="card-image">
    <% 
      submission = @user_submissions_by_quiz[quiz.id]
      reference_with_image = @quiz_covers[quiz.id] if @quiz_covers
      
      # Fallback domaine via les données pré-chargées
      if (reference_with_image.nil? || !@quiz_covers.has_key?(quiz.id)) && quiz.domaine_id
        reference_with_image = @domaine_covers[quiz.domaine_id] if @domaine_covers
      end
    %>
    <% if reference_with_image && reference_with_image.reference_images.first&.file&.attached? %>
      <%= image_tag reference_with_image.reference_images.first.file.variant(resize_to_fill: [400, 300]), loading: "lazy" %>
    <% else %>
      <div class="placeholder-img"></div>
    <% end %>
  </div>
  
  <div class="card-content">
    <div class="card-badges">
      <% if submission&.status == "completed" %>
        <% if quiz.quiz_type == 'static' %>
          <span class="badge status status-completed">
            TERMINÉ • <%= submission.score %>/<%= quiz.quiz_questions.size * 10 %> pts
          </span>
        <% else %>
          <span class="badge status status-completed">
            <% correct_count = submission.score / 10 %>
            TERMINÉ • <%= correct_count %>/<%= quiz.quiz_questions.size %> bonne<%= 's' if correct_count != 1 %> réponse<%= 's' if correct_count != 1 %>
          </span>
        <% end %>
      <% elsif submission&.status == "in_progress" %>
        <span class="badge status status-in-progress">EN COURS</span>
      <% else %>
        <span class="badge status">À FAIRE</span>
      <% end %>
      <% if quiz.domaine %>
        <span class="badge domaine" style="background-color: color-mix(in srgb, <%= quiz.domaine.couleur %>, transparent 80%); color: <%= quiz.domaine.couleur %>;">
          <%= quiz.domaine.domaine %>
        </span>
      <% end %>
    </div>

    <h3><%= quiz.title %></h3>
    
    <div class="card-info" style="font-weight: 500; font-size: 14px; margin-bottom: 20px; color: #888;">
      <%= quiz.quiz_questions.count %> Questions &bull; <%= quiz.estimated_time || 5 %> min
    </div>

    <%= link_to (quiz.in_progress_by?(current_user) ? "Continuer" : "Faire le quiz"), quiz_path(quiz), class: "button dark w-full" %>
  </div>
</div>
