<%
  user_agent_lc = request.user_agent.to_s.downcase
  ios_app_id = "6754964970"
  android_package = "com.thomasriq.omniscientdesign"

  if user_agent_lc.include?('ipad') || user_agent_lc.include?('iphone') || user_agent_lc.include?('ipod')
    store_url = "https://apps.apple.com/app/id#{ios_app_id}?action=write-review"
  elsif user_agent_lc.include?('android')
    store_url = "https://play.google.com/store/apps/details?id=#{android_package}"
  else
    store_url = root_path
  end
%>

<% set_meta_tags title: "Redirection - Omniscient Design" %>
<section class="grid-1 add-elements" style="min-height: 100dvh; display: flex; flex-direction: column; justify-content: center; align-items: center; background-color: #202020; color: #FFF; text-align: center; padding: 24px;">
  <div class="rate-redirect-card"
       data-controller="rating"
       data-rating-url-value="<%= user_signed_in? ? rate_app_badge_path : '' %>"
       data-rating-auto-trigger-value="true"
       data-rating-redirect-self-value="true"
       style="max-width: 480px; width: 100%; padding: 40px 24px; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; backdrop-filter: blur(10px); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
    
    <div class="loader-spinner" style="margin: 0 auto 32px; width: 64px; height: 64px; border: 4px solid rgba(255, 255, 255, 0.1); border-top: 4px solid #fff; border-radius: 50%; animation: spin 1s linear infinite;"></div>
    
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #FFF;"><%= t('rate_redirect.title', default: "Redirection en cours...") %></h1>
    <p style="font-size: 15px; color: #A0A0A0; line-height: 1.6; margin-bottom: 32px;">
      <%= t('rate_redirect.message', default: "Nous te redirigeons vers l'App Store ou le Google Play Store pour évaluer l'application Omniscient Design.") %>
    </p>

    <%= link_to t('rate_redirect.button', default: "Si la redirection ne marche pas"), store_url, 
                target: "_blank", 
                data: { action: "click->rating#trigger" },
                class: "button large", 
                style: "display: block; text-decoration: none; text-align: center; cursor: pointer; width: 100%; border: none; font-weight: 600; transition: transform 0.2s ease;" %>
  </div>
</section>

<style>
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>
