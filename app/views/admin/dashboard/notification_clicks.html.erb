<style>
  /* --- COPIE DU STYLE GLOBAL ADMIN --- */
  .users-dash-wrapper {
    padding: 40px 4vw 80px 4vw;
    max-width: 1600px;
    margin: 0 auto;
    background-color: #f8f9fa;
    min-height: 100vh;
    font-family: 'IBM Plex Sans', sans-serif;
    color: #202020;
    box-sizing: border-box;
  }

  /* Header */
  .users-dash-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .users-dash-title {
    font-size: 32px; font-weight: 500; color: #202020;
    display: flex; align-items: center; gap: 16px; margin: 0;
  }
  .users-dash-back-link {
    display: flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 50%;
    background-color: #fff; border: 1px solid #eee;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .users-dash-back-link:hover { background-color: #f0f0f0; transform: translateX(-2px); }

  /* Grid KPIs */
  .users-dash-kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }
  .users-dash-kpi-card {
    background: #fff; padding: 24px; border-radius: 16px;
    border: 1px solid #f0f0f0; box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    display: flex; flex-direction: column; height: 140px;
    min-width: 0;
  }
  .kpi-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .kpi-label { font-size: 12px; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
  .kpi-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .kpi-icon svg { width: 20px; height: 20px; }
  .kpi-value { font-size: 36px; font-weight: 500; color: #202020; margin-top: auto; }

  .bg-blue-light { background-color: #E3F2FD; color: #1E88E5; }
  .bg-teal-light { background-color: #E0F2F1; color: #009688; }
  .bg-green-light { background-color: #E8F5E9; color: #2E7D32; }
  .bg-amber-light { background-color: #FFF8E1; color: #FFB300; }

  /* Message Card */
  .campaign-preview-card {
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 40px;
    border: 1px solid #f0f0f0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }
  .preview-title { font-size: 20px; font-weight: 600; color: #202020; margin-top: 0; margin-bottom: 16px; }
  .preview-content { font-size: 15px; color: #555; line-height: 1.6; margin-bottom: 20px; }
  .preview-meta { display: flex; gap: 24px; font-size: 13px; color: #888; flex-wrap: wrap; }
  .meta-item { display: flex; align-items: center; gap: 6px; }
  .meta-item svg { fill: #888; width: 16px; height: 16px; }

  /* Tables */
  .section-title { font-size: 18px; font-weight: 600; color: #202020; margin-bottom: 20px; display: block; }
  
  .users-dash-table-container {
    background: #fff; border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02); border: 1px solid #f0f0f0;
    overflow: hidden;
    overflow-x: auto;
  }
  .users-dash-table { width: 100%; border-collapse: collapse; min-width: 800px; }
  .users-dash-table th {
    background-color: #fafafa; padding: 18px 24px; text-align: left;
    font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase;
    border-bottom: 1px solid #eee;
    white-space: nowrap;
  }
  .users-dash-table td {
    padding: 18px 24px; border-bottom: 1px solid #f5f5f5;
    font-size: 14px; font-weight: 500; color: #202020; vertical-align: middle;
    white-space: nowrap;
  }
  .users-dash-table tr:hover { background-color: #fcfcfc; }

  /* User Info cells */
  .user-cell { display: flex; align-items: center; gap: 12px; }
  .user-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: #202020;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600; color: #fff; overflow: hidden;
    flex-shrink: 0;
  }
  .user-info { display: flex; flex-direction: column; }
  .user-name { font-weight: 600; color: #202020; line-height: 1.2; }
  .user-email { font-size: 12px; color: #888; }

  /* Badges status */
  .status-badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .badge-unread { background: #ECEFF1; color: #546E7A; }
  .badge-read { background: #E8F5E9; color: #2E7D32; }
  .badge-not-clicked { background: #ECEFF1; color: #546E7A; }
  .badge-clicked { background: #FFF8E1; color: #FF8F00; }

  /* Responsive */
  @media (max-width: 1024px) {
    .users-dash-kpi-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .users-dash-wrapper { padding: 20px 16px 60px 16px; }
    .users-dash-title { font-size: 24px; }
    .users-dash-kpi-grid { grid-template-columns: 1fr; }
    .campaign-preview-card { padding: 20px; }
  }
</style>

<div class="users-dash-wrapper">
  <!-- Header -->
  <div class="users-dash-header">
    <div style="display: flex; align-items: center; gap: 20px;">
      <%= link_to notifications_new_path, class: "users-dash-back-link" do %>
        <svg style="width: 24px; height: 24px; fill: #202020;" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      <% end %>
      <h1 class="users-dash-title">Détails de la Campagne</h1>
    </div>
  </div>

  <!-- KPIs -->
  <div class="users-dash-kpi-grid">
    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label">Destinataires</span>
        <div class="kpi-icon bg-blue-light">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        </div>
      </div>
      <span class="kpi-value"><%= @total_sent %></span>
    </div>

    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label">Lectures (Ouv.)</span>
        <div class="kpi-icon bg-teal-light">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
        </div>
      </div>
      <span class="kpi-value"><%= @total_read %></span>
    </div>

    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label">Clics</span>
        <div class="kpi-icon bg-amber-light">
          <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
        </div>
      </div>
      <span class="kpi-value"><%= @total_clicks %></span>
    </div>

    <div class="users-dash-kpi-card">
      <div class="kpi-top">
        <span class="kpi-label">Taux de clic (CTR)</span>
        <div class="kpi-icon bg-green-light">
          <svg viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
        </div>
      </div>
      <span class="kpi-value"><%= @ctr %>%</span>
    </div>
  </div>

  <!-- Aperçu du message -->
  <div class="campaign-preview-card">
    <h2 class="preview-title"><%= @notification.title %></h2>
    <p class="preview-content"><%= @notification.message %></p>
    <div class="preview-meta">
      <% if @notification.link.present? %>
        <div class="meta-item">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
          <strong>Lien:</strong> <%= link_to @notification.link, @notification.link, target: "_blank", style: "color: #202020; text-decoration: underline;" %>
        </div>
      <% end %>
      <div class="meta-item">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
        <strong>Date d'envoi:</strong> <%= @notification.created_at.strftime("%d/%m/%Y à %H:%M") %>
      </div>
      <% if @notification.admin.present? %>
        <div class="meta-item">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
          <strong>Envoyé par:</strong> <%= @notification.admin.firstname %> <%= @notification.admin.lastname %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Tableau détaillé -->
  <span class="section-title">Destinataires & Détails des clics</span>
  <div class="users-dash-table-container">
    <table class="users-dash-table">
      <thead>
        <tr>
          <th>Utilisateur</th>
          <th>Contact</th>
          <th>Statut Notification</th>
          <th>Clic sur le lien</th>
          <th>Dernier Clic</th>
        </tr>
      </thead>
      <tbody>
        <% @campaign_notifications.each do |notif| %>
          <% user = notif.user %>
          <% next if user.nil? %>
          <tr>
            <td>
              <div class="user-cell">
                <div class="user-avatar">
                  <%= user.firstname&.first&.upcase || user.pseudo&.first&.upcase || "?" %>
                </div>
                <div class="user-info">
                  <span class="user-name"><%= user.firstname.present? ? "#{user.firstname} #{user.lastname}" : user.pseudo %></span>
                  <span class="user-email">ID: #<%= user.id %></span>
                </div>
              </div>
            </td>
            <td><%= mail_to user.email, user.email, style: "color: #666; text-decoration: none;" %></td>
            <td>
              <% if notif.read? %>
                <span class="status-badge badge-read">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  Lu
                </span>
              <% else %>
                <span class="status-badge badge-unread">Non lu</span>
              <% end %>
            </td>
            <td>
              <% if notif.clicked_at.present? %>
                <span class="status-badge badge-clicked">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
                  Cliqué
                </span>
              <% else %>
                <span class="status-badge badge-not-clicked">Pas cliqué</span>
              <% end %>
            </td>
            <td>
              <% if notif.clicked_at.present? %>
                <%= notif.clicked_at.strftime("%d/%m/%Y à %H:%M:%S") %>
              <% else %>
                <span style="color: #bbb;">-</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
