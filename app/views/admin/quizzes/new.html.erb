<div class="users-dash-wrapper">
  <div class="users-dash-header">
    <div style="display: flex; align-items: center; gap: 20px;">
      <%= link_to admin_quizzes_path, class: "users-dash-back-link" do %>
        <svg style="width: 24px; height: 24px; fill: #202020;" viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      <% end %>
      <h1 class="users-dash-title">Nouveau Quiz</h1>
    </div>
  </div>

  <div class="form-container" style="background: #fff; padding: 40px; border-radius: 20px; border: 1px solid #eee;">
    <%= render 'form', quiz: @quiz %>
  </div>
</div>
